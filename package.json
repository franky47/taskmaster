{
  "name": "taskmaster",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "imports": {
    "#lib/*": "./src/lib/*",
    "#src/*": "./src/*"
  },
  "bin": {
    "tm": "./src/main.ts"
  },
  "scripts": {
    "lint": "oxlint src/",
    "fmt": "oxfmt src/",
    "fmt:check": "oxfmt --check src/",
    "typecheck": "tsgo --noEmit",
    "test": "bun test",
    "test:integration": "bun test ./src/**/*-test.ts",
    "check": "bun run fmt:check && bun run lint && bun run typecheck && bun test && bun knip",
    "build": "bun build src/main.ts --compile --outfile tm",
    "prepare": "husky",
    "knip": "knip"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/ms": "^2.1.0",
    "@types/node": "^25.5.2",
    "@typescript/native-preview": "^7.0.0-dev.20260404.1",
    "husky": "^9.1.7",
    "knip": "^6.3.1",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "^0.19.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "cron-parser": "^5.5.0",
    "errore": "^0.14.1",
    "gray-matter": "^4.0.3",
    "ms": "^2.1.3",
    "zod": "^4.3.6"
  }
}
